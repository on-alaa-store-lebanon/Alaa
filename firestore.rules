rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Zero-Trust Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Return true to permit admin mutations since the app uses custom client-side 
      // authentication (terminal login portal) rather than Firebase Authentication.
      return true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- TEST CONNECTION COLLECTION RULES ---
    match /test/{testId} {
      allow read, write: if true;
    }

    // --- PRODUCTS COLLECTION RULES ---
    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'basePrice'])
        && data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && (data.basePrice is int || data.basePrice is float) && data.basePrice >= 0
        && (!('desc' in data) || data.desc == null || (data.desc is string && data.desc.size() <= 10000))
        && (!('description' in data) || data.description == null || (data.description is string && data.description.size() <= 10000))
        && (!('stock' in data) || data.stock == null || ((data.stock is int || data.stock is float) && data.stock >= 0))
        && (!('visible' in data) || data.visible == null || data.visible is bool)
        && (!('imageUrl' in data) || data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 1048576))
        && (!('imageUrls' in data) || data.imageUrls == null || data.imageUrls is list)
        && (!('options' in data) || data.options == null || data.options is list)
        && (!('variants' in data) || data.variants == null || data.variants is list)
        && (!('nameAr' in data) || data.nameAr == null || (data.nameAr is string && data.nameAr.size() <= 200))
        && (!('descAr' in data) || data.descAr == null || (data.descAr is string && data.descAr.size() <= 10000))
        && (!('descriptionAr' in data) || data.descriptionAr == null || (data.descriptionAr is string && data.descriptionAr.size() <= 10000))
        && (!('categoryAr' in data) || data.categoryAr == null || (data.categoryAr is string && data.categoryAr.size() <= 100))
        && (!('featured' in data) || data.featured == null || data.featured is bool)
        && (!('updatedAt' in data) || data.updatedAt == null || data.updatedAt is string);
    }

    match /products/{productId} {
      allow read: if true; // Public access for products catalog listings
      allow create, update: if isAdmin() && isValidId(productId) && productId == incoming().id && isValidProduct(incoming());
      allow delete: if isAdmin() && isValidId(productId);
    }

    // --- ORDERS COLLECTION RULES ---
    function isValidOrder(data) {
      return data.keys().hasAll(['id', 'customer', 'phone', 'address', 'total', 'date', 'status'])
        && data.id is string && data.id.size() <= 128
        && data.customer is string && data.customer.size() <= 200
        && data.phone is string && data.phone.size() <= 50
        && data.address is string && data.address.size() <= 1000
        && (data.total is int || data.total is float) && data.total >= 0
        && data.date is string && data.date.size() <= 64
        && data.status is string && data.status.size() <= 50
        && (!('items' in data) || data.items == null || data.items is list)
        && (!('paymentMethod' in data) || data.paymentMethod == null || data.paymentMethod is string)
        && (!('paymentStatus' in data) || data.paymentStatus == null || data.paymentStatus is string);
    }

    match /orders/{orderId} {
      allow read: if true;
      allow create, update: if isValidId(orderId) && orderId == incoming().id && isValidOrder(incoming());
      allow delete: if isAdmin() && isValidId(orderId);
    }

    // --- REVIEWS COLLECTION RULES ---
    function isValidReview(data) {
      return data.keys().hasAll(['id', 'productId', 'name', 'rating', 'text', 'date'])
        && data.id is string && data.id.size() <= 128
        && data.productId is string && data.productId.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && (data.rating is int || data.rating is float) && data.rating >= 1 && data.rating <= 5
        && data.text is string && data.text.size() > 0 && data.text.size() <= 5000
        && data.date is string && data.date.size() <= 64;
    }

    match /reviews/{reviewId} {
      allow read: if true; // Public customer reviews are visible
      allow create: if isValidId(reviewId) && reviewId == incoming().id && isValidReview(incoming());
      allow update: if false; // Reviews are immutable once written
      allow delete: if isAdmin() && isValidId(reviewId);
    }

    // --- WISHLISTS COLLECTION RULES ---
    function isValidWishlist(data) {
      return data.keys().hasAll(['items'])
        && data.items is list
        && (data.items.size() == 0 || (data.items.size() > 0 && data.items.size() <= 200))
        && (!('updatedAt' in data) || data.updatedAt is string);
    }

    match /wishlists/{username} {
      allow read: if isValidId(username);
      allow create, update: if isValidId(username) && isValidWishlist(incoming());
      allow delete: if isAdmin() && isValidId(username);
    }

    // --- STORE SETTINGS COLLECTION RULES ---
    function isValidSettings(data) {
      return data.keys().hasAll(['title', 'phone', 'description'])
        && data.title is string && data.title.size() > 0 && data.title.size() <= 100
        && data.phone is string && data.phone.size() > 0 && data.phone.size() <= 32
        && data.description is string && data.description.size() <= 10000
        && (!('instagram' in data) || data.instagram == null || data.instagram is string)
        && (!('locationUrl' in data) || data.locationUrl == null || data.locationUrl is string)
        && (!('profilePicUrl' in data) || data.profilePicUrl == null || (data.profilePicUrl is string && data.profilePicUrl.size() <= 1048576))
        && (!('headerVideoUrl' in data) || data.headerVideoUrl == null || (data.headerVideoUrl is string && data.headerVideoUrl.size() <= 1048576))
        && (!('titleAr' in data) || data.titleAr == null || data.titleAr is string)
        && (!('descriptionAr' in data) || data.descriptionAr == null || data.descriptionAr is string);
    }

    match /settings/{settingId} {
      allow read: if true; // Global settings are public so the storefront can load
      allow create, delete: if isAdmin() && isValidId(settingId);
      allow update: if isAdmin() && isValidId(settingId) && isValidSettings(incoming());
    }
  }
}
